# HINWEIS: Diese Datei ist NUR für die Lovable-Preview.
# Für IONOS-Produktion → public/htaccess-ionos verwenden!
# (wird automatisch beim Build nach dist/.htaccess kopiert)

Options -MultiViews

RewriteEngine On

# ============================================
# CACHE-KONTROLLE (Lighthouse Performance Fix)
# ============================================

<IfModule mod_headers.c>
  <FilesMatch "\.(css|js|png|jpg|jpeg|webp|svg|woff2)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.(html)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType text/javascript "access plus 1 year"
  ExpiresByType application/json "access plus 1 day"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/plain text/html text/xml text/css
  AddOutputFilterByType DEFLATE application/javascript application/x-javascript text/javascript
  AddOutputFilterByType DEFLATE application/json application/xml image/svg+xml
</IfModule>

<IfModule mod_brotli.c>
  AddOutputFilterByType BROTLI_COMPRESS text/plain text/html text/xml text/css
  AddOutputFilterByType BROTLI_COMPRESS application/javascript application/x-javascript text/javascript
  AddOutputFilterByType BROTLI_COMPRESS application/json application/xml image/svg+xml
</IfModule>

# ============================================
# SEO: HTTPS + WWW Redirect (einheitliche URL-Struktur)
# Canonical: https://www.kraftfahrer-mieten.com/
# ============================================

# 1. Force HTTPS first (before www redirect)
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# 2. Force WWW (nach HTTPS)
RewriteCond %{HTTP_HOST} ^kraftfahrer-mieten\.com$ [NC]
RewriteRule ^(.*)$ https://www.kraftfahrer-mieten.com/$1 [R=301,L]

# Bypass all rewrites for admin-check.html (serve static)
RewriteRule ^admin-check\.html$ - [L]

# MIME types for images
AddType image/jpeg .jpg .jpeg
AddType image/png .png

# Prevent partial content to avoid 206 issues for crawlers
<IfModule mod_headers.c>
  Header set Accept-Ranges none
</IfModule>

# Legacy .html → clean URLs (THE_REQUEST = nur echte Browser-Anfragen, nicht SPA-Rewrite)
RewriteCond %{THE_REQUEST} \s/+index\.html[\s?] [NC]
RewriteRule ^index\.html$ / [R=301,L]

RewriteCond %{THE_REQUEST} \s/+impressum\.html[\s?] [NC]
RewriteRule ^impressum\.html$ /impressum [R=301,L]

RewriteCond %{THE_REQUEST} \s/+datenschutzerklaerung\.html[\s?] [NC]
RewriteRule ^datenschutzerklaerung\.html$ /datenschutz [R=301,L]

RewriteCond %{THE_REQUEST} \s/+allgemeine-geschaeftsbedingungen\.html[\s?] [NC]
RewriteRule ^allgemeine-geschaeftsbedingungen\.html$ /agb [R=301,L]

# Legacy mobile/smartphone/printable/vgapda URLs → Homepage
RewriteRule ^mobile/.* / [R=301,L]
RewriteRule ^smartphone/.* / [R=301,L]
RewriteRule ^printable/.* / [R=301,L]
RewriteRule ^vgapda/.* / [R=301,L]

# Referenzen variants
RewriteRule ^referenzen/default\.html$ /referenzen [R=301,L]
RewriteRule ^referenzen/(mobile|smartphone|printable)/.*default\.html$ /referenzen [R=301,L]

# PHP files → Homepage
RewriteCond %{REQUEST_URI} \.php$ [NC]
RewriteRule ^ / [R=301,L]

# Generic .html → clean URL (außer admin-check.html und index.html)
RewriteCond %{THE_REQUEST} \.html[\s?] [NC]
RewriteCond %{REQUEST_URI} !^/admin-check\.html$ [NC]
RewriteCond %{REQUEST_URI} !^/index\.html$ [NC]
RewriteRule ^(.+)\.html$ /$1 [R=301,L]

# Entfernte Seiten
RewriteRule ^fahrerboerse$ - [G,L]

# SPA fallback routing
RewriteBase /

# Statische Dateien direkt ausliefern
RewriteRule \.(css|js|jpg|jpeg|png|gif|webp|avif|svg|ico|woff|woff2|ttf|otf|eot|mp4|pdf|map)$ - [L]
RewriteRule ^(robots\.txt|sitemap\.xml|favicon\.ico|favicon\.png|admin-check\.html)$ - [L]
RewriteRule ^manifest\.webmanifest$ - [L]
RewriteRule ^sw\.js$ - [L]
RewriteRule ^workbox-.*\.js$ - [L]
RewriteRule ^assets/ - [L]

# SPA Catch-all (INTERNER REWRITE – kein Redirect!)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ /index.html [L]